# Strava app credentials — get yours from https://strava.com/settings/api
# The CLIENT_ID is public (it's in the authorize URL). The CLIENT_SECRET
# stays on the Cloudflare Worker, never the browser.
VITE_STRAVA_CLIENT_ID=

# Cloudflare Worker URL (from `wrangler deploy`). For local worker dev:
#   VITE_OAUTH_WORKER_URL=http://localhost:8787
VITE_OAUTH_WORKER_URL=

# Where Strava redirects after the user approves. Must match exactly one
# of the callback domains registered in your Strava API settings (only the
# scheme/host/port is matched — the path can be anything you want as long
# as it points at this app).
#   Local dev:  http://localhost:3000/callback
#   Production: https://strava-overlay-shell.netlify.app/callback
VITE_REDIRECT_URI=http://localhost:3000/callback
